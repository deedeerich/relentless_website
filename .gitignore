# ============================================
# RELENTLESS .gitignore — Security-First
# ============================================

# ----- Secrets & Environment -----
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.p12
*.pfx
*.jks
*.keystore
credentials.json
service-account*.json
*secret*
*token*
!**/token*.liquid

# ----- OS Files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ----- IDE / Editor -----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/

# ----- Node -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn/cache
.pnp.*

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.python-version

# ----- Shopify -----
# Theme settings generated by Shopify admin (contains store-specific config)
shopify/theme/config/settings_data.json

# ----- Logs -----
*.log
logs/

# ----- Build artifacts -----
*.zip
*.tar.gz
*.tgz

# ----- Backup files -----
*.bak
*.backup
*.old
*.orig
