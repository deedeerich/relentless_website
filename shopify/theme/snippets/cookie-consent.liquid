{%- comment -%}
  Cookie Consent Banner — GDPR / CCPA compliance.
  Shows on first visit. Acceptance stored in localStorage via relentless.js.
  Controlled by theme setting: show_cookie_consent.
{%- endcomment -%}

{% if settings.show_cookie_consent %}
<div id="cookie-consent-banner"
     class="cookie-consent"
     role="dialog"
     aria-label="{{ 'cookie_consent.title' | t | default: 'Cookie consent' }}"
     aria-describedby="cookie-consent-message"
     hidden>
  <div class="cookie-consent__inner">
    <p id="cookie-consent-message">
      {{ 'cookie_consent.message' | t | default: 'We use cookies to improve your experience and for analytics.' }}
      {% if settings.privacy_policy_url != blank %}
        <a href="{{ settings.privacy_policy_url }}">{{ 'cookie_consent.privacy_link' | t | default: 'Privacy Policy' }}</a>
      {% endif %}
      {% if settings.show_ccpa_notice and settings.privacy_policy_url != blank %}
        <br>{{ 'cookie_consent.ccpa_prefix' | t | default: 'California residents:' }}
        <a href="{{ settings.privacy_policy_url }}#ccpa">{{ 'cookie_consent.ccpa_link' | t | default: 'Do Not Sell My Personal Information' }}</a>
      {% endif %}
    </p>
    <div class="cookie-consent__actions">
      <button class="cookie-consent__accept" data-cookie-accept>
        {{ 'cookie_consent.accept' | t | default: 'Accept' }}
      </button>
      {% if settings.privacy_policy_url != blank %}
        <a href="{{ settings.privacy_policy_url }}" class="cookie-consent__learn-more">
          {{ 'cookie_consent.learn_more' | t | default: 'Learn More' }}
        </a>
      {% endif %}
    </div>
  </div>
</div>
{% endif %}
