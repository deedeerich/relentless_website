{% comment %}
  main-page.liquid
  Default page template — renders page title and content.
  Used when no custom template (page.philosophy, page.still-building, etc.) is assigned.
{% endcomment %}

<section class="default-page">
  <div class="page-inner">
    <h1>{{ page.title }}</h1>
    <div class="page-body">{{ page.content }}</div>
  </div>
</section>

{% schema %}
{
  "name": "Default Page",
  "tag": "div",
  "class": "main-page-section"
}
{% endschema %}
