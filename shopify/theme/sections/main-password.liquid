{% comment %}
  main-password.liquid
  Password/storefront lock page — shown when store is password-protected.
{% endcomment %}

<section class="password-page">
  <div class="password-inner">
    <h1>RELENTLESS</h1>
    <p class="password-tagline">Nothing Is Finished.</p>
    <p>We're building something. Come back soon.</p>

    {% form 'storefront_password' %}
      <div class="password-form">
        <label for="password-input" class="visually-hidden">Store password</label>
        <input type="password" id="password-input" name="password" placeholder="Enter password" autocomplete="current-password">
        <button type="submit">Enter</button>
      </div>
      {% if form.errors %}
        <p class="password-error">{{ form.errors | default_errors }}</p>
      {% endif %}
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Password Page",
  "tag": "div",
  "class": "main-password-section"
}
{% endschema %}
