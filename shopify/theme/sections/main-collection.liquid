{% comment %}
  main-collection.liquid
  Collection grid — product cards with image, title, price.
{% endcomment %}

<section class="collection-page">
  <div class="collection-inner">
    <div class="collection-header">
      <h1 class="collection-title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <div class="collection-description">{{ collection.description }}</div>
      {% endif %}
    </div>

    {% if collection.products.size > 0 %}
      <div class="product-grid">
        {% for product in collection.products %}
          <a href="{{ product.url }}" class="product-card">
            {% if product.featured_image %}
              {{ product.featured_image | image_url: width: 400 | image_tag: alt: product.title, loading: 'lazy' }}
            {% endif %}
            <div class="product-card-info">
              <h2 class="product-card-title">{{ product.title }}</h2>
              <p class="product-card-price">{{ product.price | money }}</p>
            </div>
          </a>
        {% endfor %}
      </div>
    {% else %}
      <div class="collection-empty">
        <p>{{ 'shop.coming_soon' | t | default: 'Coming Soon — Stay tuned for exclusive drops.' }}</p>
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Collection Page",
  "tag": "div",
  "class": "main-collection-section"
}
{% endschema %}
