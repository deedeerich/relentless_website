{% comment %} main-customer-activate.liquid — Account activation {% endcomment %}

<section class="customer-page">
  <div class="customer-inner">
    <h1>Activate Account</h1>
    <p>Create a password to activate your account.</p>

    {% form 'activate_customer_password' %}
      {% if form.errors %}
        <div class="form-errors">{{ form.errors | default_errors }}</div>
      {% endif %}
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="customer[password]" autocomplete="new-password" required>
      </div>
      <div class="form-group">
        <label for="password_confirmation">Confirm Password</label>
        <input type="password" id="password_confirmation" name="customer[password_confirmation]" autocomplete="new-password" required>
      </div>
      <button type="submit">Activate Account</button>
    {% endform %}
  </div>
</section>

{% schema %}
{ "name": "Activate Account", "tag": "div", "class": "main-customer-activate-section" }
{% endschema %}
