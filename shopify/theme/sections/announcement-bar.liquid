{% comment %}
  announcement-bar.liquid
  Top announcement bar — hidden by default, enable via section settings.
{% endcomment %}

{% if section.settings.show_bar %}
<div class="announcement-bar" role="region" aria-label="Announcement">
  <div class="announcement-bar-inner">
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}" class="announcement-bar-link">
        {{ section.settings.text | default: 'Nothing Is Finished. Join the Movement.' }}
      </a>
    {% else %}
      <p>{{ section.settings.text | default: 'Nothing Is Finished. Join the Movement.' }}</p>
    {% endif %}
  </div>
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "div",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show announcement bar",
      "default": false
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Nothing Is Finished. Join the Movement."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
