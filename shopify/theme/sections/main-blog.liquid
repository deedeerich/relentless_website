{% comment %}
  main-blog.liquid
  Blog listing page — article cards in a grid.
{% endcomment %}

<section class="blog-page">
  <div class="blog-inner">
    <h1 class="blog-title">{{ blog.title }}</h1>

    {% if blog.articles.size > 0 %}
      <div class="blog-grid">
        {% for article in blog.articles %}
          <article class="blog-card">
            {% if article.image %}
              <a href="{{ article.url }}" class="blog-card-image">
                {{ article.image | image_url: width: 600 | image_tag: alt: article.title, loading: 'lazy' }}
              </a>
            {% endif %}
            <div class="blog-card-content">
              <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">{{ article.published_at | date: '%B %d, %Y' }}</time>
              <h2><a href="{{ article.url }}">{{ article.title }}</a></h2>
              <p>{{ article.excerpt_or_content | strip_html | truncatewords: 25 }}</p>
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="blog-empty">
        <p>Content is coming. Check back soon.</p>
      </div>
    {% endif %}

    {% if blog.articles.size > 20 %}
      <div class="pagination">{{ paginate | default_pagination }}</div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Blog Page",
  "tag": "div",
  "class": "main-blog-section"
}
{% endschema %}
