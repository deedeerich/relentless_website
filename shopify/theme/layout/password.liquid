<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Relentless — Nothing Is Finished</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Barlow:wght@300;400;500;600;700&family=Barlow+Condensed:wght@300;400;600;700&display=swap" rel="stylesheet">

  {{ 'relentless.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>

<body class="password-page">

  <canvas id="starfield" aria-hidden="true" role="presentation"></canvas>

  <div class="password-lockup">
    <div class="hero-title-block">
      <div class="hero-title-main">
        <span class="ht-nothing">NOTHING</span>
        <span class="ht-is">is</span>
        <span class="ht-finished">FINISHED</span>
      </div>
      <div class="hero-title-sub-row">
        <div class="gold-rule-long"></div>
        <span class="hero-relentless">RELENTLESS</span>
        <div class="gold-rule-long"></div>
      </div>
    </div>

    <p class="password-tagline">Nothing is finished. We are still building.</p>
    <p class="password-sub">Something is coming. Every day. Every step.</p>

    {% form 'storefront_password' %}
      <div class="password-form">
        <label for="Password" class="sr-only">Store password</label>
        <input type="password"
               name="password"
               id="Password"
               class="password-input"
               placeholder="Enter password"
               autofocus>
        <button type="submit" class="password-btn">Enter</button>
      </div>
      {% if form.errors %}
        <p class="password-error" role="alert">{{ form.errors | default_errors }}</p>
      {% endif %}
    {% endform %}
  </div>

  {{ content_for_layout }}

  <script src="{{ 'relentless.js' | asset_url }}" defer></script>
</body>
</html>
