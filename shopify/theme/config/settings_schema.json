[
  {
    "name": "theme_info",
    "theme_name": "Relentless",
    "theme_version": "1.0.0",
    "theme_author": "Lighthouse Global",
    "theme_documentation_url": "https://github.com/deedeerich/relentless_website",
    "theme_support_url": "mailto:dev@lighthouseglobal.io"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo (dark background)"
      },
      {
        "type": "image_picker",
        "id": "logo_light",
        "label": "Logo (light background / inverted)"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "text",
        "id": "brand_tagline",
        "label": "Brand tagline",
        "default": "Nothing Is Finished"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_dark",
        "label": "Dark (warm black)",
        "default": "#050403"
      },
      {
        "type": "color",
        "id": "color_white",
        "label": "Warm white",
        "default": "#f5f0e8"
      },
      {
        "type": "color",
        "id": "color_gold",
        "label": "Gold accent",
        "default": "#D4982E"
      },
      {
        "type": "color",
        "id": "color_gold_light",
        "label": "Gold light",
        "default": "#e8b54a"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "url",
        "id": "social_youtube",
        "label": "YouTube URL",
        "default": "https://www.youtube.com/@relentlessperforma"
      },
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram URL",
        "default": "https://www.instagram.com/relentlessperforma"
      },
      {
        "type": "text",
        "id": "youtube_channel_id",
        "label": "YouTube Channel ID",
        "info": "Used for channel embed (e.g. UCxxxxxxxxxx)"
      }
    ]
  },
  {
    "name": "Integrations",
    "settings": [
      {
        "type": "text",
        "id": "klaviyo_public_key",
        "label": "Klaviyo public API key",
        "info": "Found in Klaviyo > Account > Settings > API Keys"
      },
      {
        "type": "text",
        "id": "klaviyo_waitlist_list_id",
        "label": "Klaviyo waitlist list ID",
        "info": "List ID for the shop drop waitlist"
      }
    ]
  },
  {
    "name": "Legal & Compliance",
    "settings": [
      {
        "type": "url",
        "id": "privacy_policy_url",
        "label": "Privacy Policy URL"
      },
      {
        "type": "url",
        "id": "terms_url",
        "label": "Terms of Service URL"
      },
      {
        "type": "url",
        "id": "community_guidelines_url",
        "label": "Community Guidelines URL"
      },
      {
        "type": "url",
        "id": "accessibility_url",
        "label": "Accessibility Statement URL"
      },
      {
        "type": "checkbox",
        "id": "show_cookie_consent",
        "label": "Show cookie consent banner",
        "default": true,
        "info": "Required for GDPR compliance"
      },
      {
        "type": "checkbox",
        "id": "show_ccpa_notice",
        "label": "Show CCPA Do Not Sell link",
        "default": true,
        "info": "Required for California residents"
      }
    ]
  }
]
