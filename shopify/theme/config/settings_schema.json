[
  {
    "name": "theme_info",
    "theme_name": "Relentless",
    "theme_version": "1.0.0",
    "theme_author": "Lighthouse Global",
    "theme_documentation_url": "https://github.com/deedeerich/relentless_website",
    "theme_support_url": "mailto:dev@lighthouseglobal.io"
  },
  {
    "name": "Brand",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      },
      {
        "type": "text",
        "id": "brand_tagline",
        "label": "Brand tagline",
        "default": "Nothing Is Finished"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary (Black)",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary (White)",
        "default": "#FFFFFF"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (Gold)",
        "default": "#C5A55A"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#FFFFFF"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "montserrat_n7"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "montserrat_n4"
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "url",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook URL"
      }
    ]
  },
  {
    "name": "Integrations",
    "settings": [
      {
        "type": "text",
        "id": "klaviyo_public_key",
        "label": "Klaviyo public API key",
        "info": "Found in Klaviyo > Account > Settings > API Keys"
      }
    ]
  },
  {
    "name": "Legal & Compliance",
    "settings": [
      {
        "type": "url",
        "id": "privacy_policy_url",
        "label": "Privacy Policy URL"
      },
      {
        "type": "url",
        "id": "terms_url",
        "label": "Terms of Service URL"
      },
      {
        "type": "url",
        "id": "community_guidelines_url",
        "label": "Community Guidelines URL"
      },
      {
        "type": "checkbox",
        "id": "show_cookie_consent",
        "label": "Show cookie consent banner",
        "default": true,
        "info": "Required for GDPR compliance"
      },
      {
        "type": "checkbox",
        "id": "show_ccpa_notice",
        "label": "Show CCPA Do Not Sell link",
        "default": true,
        "info": "Required for California residents"
      }
    ]
  }
]
